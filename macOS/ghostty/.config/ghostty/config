# TERM: use xterm-256color for consistent color rendering with tmux (tmux-256color inside)
term = xterm-256color

# Colors: match alacritty default (Tomorrow Night)
background = #1d1f21
foreground = #c5c8c6

# Clipboard: allow OSC 52 read and write
clipboard-read = allow
clipboard-write = allow

# Window size (in cells)
window-width = 180
window-height = 60

# Disable shell integration cursor control so cursor-style = block is preserved at prompt
# (tmux uses Se=\E[2 q block as default; ghostty shell integration would override to bar)
shell-integration-features = no-cursor,no-sudo,no-title,no-ssh-env,no-ssh-terminfo,path
title = Rubber Duck

# Treat both Option keys as Alt on macOS
macos-option-as-alt = true

# Font
font-family = Consolas Nerd Font
font-size = 16
# macOS font thickening to match alacritty's subpixel antialiasing rendering
# strength range: 0 (lightest) - 255 (heaviest), tune to taste
font-thicken = true
font-thicken-strength = 100

# Cursor: block to match tmux default (Se=\E[2 q)
cursor-style = block

# Disable close confirmation dialog
confirm-close-surface = false

# Keybindings
keybind = alt+v=paste_from_clipboard
keybind = alt+c=copy_to_clipboard

# Send proper xterm escape sequences for Alt+Arrow keys
keybind = alt+left=csi:1;3D
keybind = alt+right=csi:1;3C
keybind = alt+up=csi:1;3A
keybind = alt+down=csi:1;3B
