#!/usr/bin/env bash

# Input:  $0|mysession|1|vim     (session_id|session_name|window_index|window_name)
# Output: mysession            12      vim     $0:1
#         col1(display name)   col2    col3    col4(hidden, used for jump)
# col2: session_id strips '$' and +1 to make it 1-based, then concat window_index
# col4: original session_id:window_index, passed to `tmux switch-client -t`
current=$(tmux display-message -p '#{session_id}:#{window_index}')

list=$(tmux list-windows -a -F '#{session_id}|#{session_name}|#{window_index}|#{window_name}' |
	grep -v '^[^|]*|_' | # ignore session created by Ataraxy-Labs/opensessions
	sort -t'$' -k2 -n |
	awk -F'|' 'BEGIN {
		# Catppuccin Mocha: peach, green, mauve, sapphire, red, yellow, teal
		split("38;2;250;179;135|38;2;166;227;161|38;2;203;166;247|38;2;116;199;236|38;2;243;139;168|38;2;249;226;175|38;2;148;226;213", codes, "|")
		nc = 7
	} {
		if ($1 != prev) ci++
		c = "\033[" codes[(ci-1) % nc + 1] "m"
		r = "\033[0m"
		name = ($1 != prev) ? $2 : ""
		printf "%s%-20s\t%-4s\t%s%s\t%s\n", c, name, (substr($1,2)+1)$3, $4, r, $1":"$3
		prev = $1
	}')

pos=$(echo "$list" | awk -F'\t' -v cur="$current" '$NF == cur {print NR; exit}')

selected=$(echo "$list" |
	fzf --ansi --reverse --border=none --height=100% --prompt=' ' --pointer='▶' --cycle \
		--delimiter='\t' --with-nth=1,2,3 --nth=2,3 \
		--bind "load:pos(${pos:-1})" --bind "change:first" |
	awk -F'\t' '{print $NF}')

[[ -n "$selected" ]] && tmux switch-client -t "$selected"
